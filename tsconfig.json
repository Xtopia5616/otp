{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    // --- 严格模式（Engineering §1.2）---
    "strict": true,
    "noUncheckedIndexedAccess": true, // 数组/对象索引访问强制 null 检查
    "strictNullChecks": true, // 隐含于 strict，显式声明强调
    "strictFunctionTypes": true, // 隐含于 strict，显式声明强调
    "noImplicitReturns": true, // 加密函数不允许隐式返回 undefined

    // --- 模块系统（generated 已含，显式对齐文档）---
    "verbatimModuleSyntax": true, // import type 必须显式标注
    "module": "ESNext",
    "moduleResolution": "bundler", // SvelteKit 推荐
    "target": "ES2022", // 支持 top-level await / structuredClone
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // --- 路径别名（Engineering §1.2）---
    // $lib / $server 由 SvelteKit kit.alias 提供（svelte.config.js）。
    // 不在 tsconfig.json 手动声明 paths，避免与 SvelteKit 自动生成的 tsconfig 冲突。

    // --- 输出 ---
    // 应用不产出 .d.ts 声明（svelte-check/vite 均不 emit）；
    // `declaration:true` 会导致 betterAuth() 等返回类型因引用不可命名符号触发 TS2742，故移除。
    "outDir": ".svelte-kit/types",
    "sourceMap": true,

    // --- 其他 ---
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true, // esbuild/Svelte 编译器要求
    "rewriteRelativeImportExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true
  },
  // include 须显式补 SvelteKit 生成的 ambient 声明文件（$env/* 模块声明所在）：
  // 继承的 `**/*.ts` 不覆盖 .svelte-kit/ 下的 ambient.d.ts，致 $env/* 不可见。
  // `$server-only` 的 ambient 声明由 src/server-only-ambient.ts 提供（svelte-check
  // 不加载 glob 匹配的 .d.ts，故用 .ts 脚本文件承载全局 ambient 模块声明）。
  "include": [
    "src/**/*",
    "tests/**/*",
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/env.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "src/service-worker.ts", "src/service-worker/**"]
}
