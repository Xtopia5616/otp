# WebOTP 环境变量模板（DevSetup §5.1）
# 复制为 .env 并填入真实值；.env 不得提交版本控制。

# 数据库连接（DevSetup 附录 A：Node ≥ 17 优先 IPv6，
# 若 ECONNREFUSED ::1:5432，用 127.0.0.1 替代 localhost）
DATABASE_URL=postgresql://webotp:dev@127.0.0.1:5432/webotp_dev

# Better Auth 会话签名密钥（≥ 32 字节）
# 生成：openssl rand -hex 32
BETTER_AUTH_SECRET=

# 应用公开 URL（开发环境为 Vite dev server）
BETTER_AUTH_URL=http://localhost:5173

# 反枚举防御 HMAC 密钥（256 位随机 hex，见架构 §8.1）
# 生成：openssl rand -hex 32
# ⚠️ 必须与 BETTER_AUTH_SECRET 不同
SERVER_SECRET=

# CORS 受信源（逗号分隔，可选）
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
